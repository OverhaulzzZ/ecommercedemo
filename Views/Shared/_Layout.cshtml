<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AutoRepuestos Express</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
            <i class="fas fa-car-side text-warning me-2"></i>AutoRepuestos<span class="text-warning">Express</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <form class="d-flex mx-auto my-2 my-lg-0" style="width:40%;" method="get" asp-controller="Catalogo" asp-action="Index">
                <div class="input-group">
                    <input class="form-control" type="search" name="q" placeholder="Buscar repuesto, marca, modelo..." value="@ViewData["BusquedaActual"]" />
                    <button class="btn btn-warning" type="submit"><i class="fas fa-search"></i></button>
                </div>
            </form>

            <ul class="navbar-nav ms-auto align-items-center gap-1">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="fas fa-home me-1"></i>Inicio</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Catalogo" asp-action="Index"><i class="fas fa-list me-1"></i>Catálogo</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link position-relative" asp-controller="Carrito" asp-action="Index">
                        <i class="fas fa-shopping-cart me-1"></i>Carrito
                        @if (ViewData["CantidadCarrito"] != null && (int)ViewData["CantidadCarrito"]! > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark">
                                @ViewData["CantidadCarrito"]
                            </span>
                        }
                    </a>
                </li>
                <li class="nav-item ms-2">
                    <a class="btn btn-warning btn-sm fw-semibold" asp-controller="Admin" asp-action="Index">
                        <i class="fas fa-cogs me-1"></i>Admin
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container-fluid px-0">
    @RenderBody()
</div>

<footer class="bg-dark text-white mt-5 py-4">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <h5 class="text-warning fw-bold"><i class="fas fa-car-side me-2"></i>AutoRepuestos Express</h5>
                <p class="text-white-50 small">Tu proveedor de confianza en repuestos automotrices originales y alternos. Calidad garantizada.</p>
            </div>
            <div class="col-md-4">
                <h6 class="fw-semibold">Categorías</h6>
                <ul class="list-unstyled text-white-50 small">
                    <li><a href="/Catalogo?categoriaId=1" class="text-white-50 text-decoration-none">Motor y Aceites</a></li>
                    <li><a href="/Catalogo?categoriaId=2" class="text-white-50 text-decoration-none">Sistema de Frenos</a></li>
                    <li><a href="/Catalogo?categoriaId=3" class="text-white-50 text-decoration-none">Suspensión</a></li>
                    <li><a href="/Catalogo?categoriaId=4" class="text-white-50 text-decoration-none">Sistema Eléctrico</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 class="fw-semibold">Contacto</h6>
                <ul class="list-unstyled text-white-50 small">
                    <li><i class="fas fa-phone me-2"></i>+1 (555) 123-4567</li>
                    <li><i class="fas fa-envelope me-2"></i>ventas@autorepuestosexpress.com</li>
                    <li><i class="fas fa-map-marker-alt me-2"></i>123 Calle Principal, Ciudad</li>
                </ul>
            </div>
        </div>
        <hr class="border-secondary mt-3 mb-2" />
        <p class="text-center text-white-50 small mb-0">&copy; @DateTime.Now.Year AutoRepuestos Express. Todos los derechos reservados.</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
