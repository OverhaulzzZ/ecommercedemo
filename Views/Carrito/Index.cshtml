@using EcommerceDemo.Models
@model List<CarritoItem>
@{
    ViewData["Title"] = "Mi Carrito";
    decimal total = ViewBag.Total ?? 0m;
}

<div class="container py-4">
    <h2 class="fw-bold mb-4"><i class="fas fa-shopping-cart text-warning me-2"></i>Mi Carrito</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">Tu carrito está vacío</h4>
            <p class="text-muted">Agrega productos desde nuestro catálogo.</p>
            <a asp-controller="Catalogo" asp-action="Index" class="btn btn-warning btn-lg mt-2">
                <i class="fas fa-search me-2"></i>Ver Catálogo
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-0">
                        @foreach (var item in Model)
                        {
                            <div class="d-flex align-items-center gap-3 p-3 border-bottom">
                                <div class="img-placeholder rounded" style="width:70px; height:70px; min-height:unset; font-size:1.5rem; flex-shrink:0;">
                                    <i class="fas fa-cog"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-0 fw-semibold">@item.Nombre</h6>
                                    <small class="text-muted">Precio unitario: $@item.Precio.ToString("F2")</small>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <form asp-action="Actualizar" method="post" class="d-flex align-items-center gap-1">
                                        <input type="hidden" name="productoId" value="@item.ProductoId" />
                                        <button type="submit" name="cantidad" value="@(item.Cantidad - 1)"
                                                class="btn btn-outline-secondary btn-sm px-2">-</button>
                                        <span class="fw-semibold px-2">@item.Cantidad</span>
                                        <button type="submit" name="cantidad" value="@(item.Cantidad + 1)"
                                                class="btn btn-outline-secondary btn-sm px-2">+</button>
                                    </form>
                                    <span class="fw-bold text-dark" style="min-width:70px; text-align:right;">$@item.Subtotal.ToString("F2")</span>
                                    <form asp-action="Eliminar" method="post">
                                        <input type="hidden" name="productoId" value="@item.ProductoId" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="mt-3">
                    <a asp-controller="Catalogo" asp-action="Index" class="btn btn-outline-dark">
                        <i class="fas fa-arrow-left me-1"></i>Seguir comprando
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 sticky-top" style="top:80px;">
                    <div class="card-header bg-dark text-white fw-semibold">Resumen del pedido</div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal (@Model.Sum(i => i.Cantidad) artículos)</span>
                            <span>$@total.ToString("F2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Envío</span>
                            @if (total >= 50)
                            {
                                <span class="text-success fw-semibold">Gratis</span>
                            }
                            else
                            {
                                <span>$5.00</span>
                            }
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5 mb-3">
                            <span>Total</span>
                            <span>$@((total >= 50 ? total : total + 5).ToString("F2"))</span>
                        </div>
                        @if (total < 50)
                        {
                            <div class="alert alert-info p-2 small mb-3">
                                <i class="fas fa-info-circle me-1"></i>Agrega $@((50 - total).ToString("F2")) más para envío gratis
                            </div>
                        }
                        <a asp-controller="Checkout" asp-action="Index" class="btn btn-warning w-100 fw-bold btn-lg">
                            <i class="fas fa-lock me-2"></i>Proceder al pago
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
