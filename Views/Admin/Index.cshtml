@using EcommerceDemo.Models
@{
    ViewData["Title"] = "Dashboard";
    ViewData["AdminPage"] = "dashboard";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    var ultimasOrdenes = ViewBag.UltimasOrdenes as List<Orden> ?? new();
    var stockBajoList = ViewBag.ProductosStockBajo as List<Producto> ?? new();
}

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10">
                    <i class="fas fa-boxes-stacked text-primary"></i>
                </div>
                <div>
                    <div class="text-muted small">Productos activos</div>
                    <div class="fs-3 fw-bold">@ViewBag.TotalProductos</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10">
                    <i class="fas fa-receipt text-success"></i>
                </div>
                <div>
                    <div class="text-muted small">Órdenes totales</div>
                    <div class="fs-3 fw-bold">@ViewBag.TotalOrdenes</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-warning bg-opacity-10">
                    <i class="fas fa-dollar-sign text-warning"></i>
                </div>
                <div>
                    <div class="text-muted small">Ventas totales</div>
                    <div class="fs-3 fw-bold">$@(((decimal)ViewBag.VentasTotal).ToString("F0"))</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-danger bg-opacity-10">
                    <i class="fas fa-triangle-exclamation text-danger"></i>
                </div>
                <div>
                    <div class="text-muted small">Stock bajo</div>
                    <div class="fs-3 fw-bold">@ViewBag.StockBajo</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Últimas órdenes -->
    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Últimas Órdenes</span>
                <a asp-action="Ordenes" class="btn btn-sm btn-outline-primary">Ver todas</a>
            </div>
            <div class="card-body p-0">
                @if (!ultimasOrdenes.Any())
                {
                    <p class="text-muted text-center py-4">Aún no hay órdenes registradas.</p>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="small">Orden</th>
                                <th class="small">Cliente</th>
                                <th class="small">Total</th>
                                <th class="small">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in ultimasOrdenes)
                            {
                                <tr>
                                    <td><a asp-action="DetalleOrden" asp-route-id="@o.Id" class="text-decoration-none fw-semibold small">@o.NumeroOrden</a></td>
                                    <td class="small">@o.ClienteNombre</td>
                                    <td class="small fw-semibold">$@o.Total.ToString("F2")</td>
                                    <td>
                                        @{
                                            var badgeClass = o.Estado switch {
                                                EstadoOrden.Entregada => "bg-success",
                                                EstadoOrden.Cancelada => "bg-danger",
                                                EstadoOrden.Enviada => "bg-info",
                                                EstadoOrden.Confirmada => "bg-primary",
                                                EstadoOrden.EnProceso => "bg-warning text-dark",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@o.Estado</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Stock bajo -->
    <div class="col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold text-danger"><i class="fas fa-triangle-exclamation me-2"></i>Stock Bajo</span>
                <a asp-action="Productos" class="btn btn-sm btn-outline-danger">Gestionar</a>
            </div>
            <div class="card-body p-0">
                @if (!stockBajoList.Any())
                {
                    <p class="text-muted text-center py-4">Todos los productos tienen stock suficiente.</p>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th class="small">Producto</th><th class="small">Stock</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var p in stockBajoList)
                            {
                                <tr>
                                    <td class="small">@p.Nombre</td>
                                    <td>
                                        <span class="badge @(p.Stock == 0 ? "badge-stock-out" : "badge-stock-low")">@p.Stock ud.</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
