<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin | AutoRepuestos Express</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-light">

<div class="d-flex" style="min-height:100vh;">
    <!-- Sidebar -->
    <div class="admin-sidebar d-flex flex-column p-3" style="width:240px; min-width:240px;">
        <a asp-controller="Home" asp-action="Index" class="text-decoration-none mb-4 d-block">
            <span class="text-warning fw-bold fs-5"><i class="fas fa-car-side me-2"></i>AutoRepuestos</span>
            <div class="text-white-50 small">Panel de Administración</div>
        </a>
        <nav class="nav flex-column gap-1 flex-grow-1">
            <a asp-controller="Admin" asp-action="Index"
               class="nav-link px-3 py-2 @(ViewData["AdminPage"]?.ToString() == "dashboard" ? "active" : "")">
                <i class="fas fa-chart-bar me-2"></i>Dashboard
            </a>
            <a asp-controller="Admin" asp-action="Productos"
               class="nav-link px-3 py-2 @(ViewData["AdminPage"]?.ToString() == "productos" ? "active" : "")">
                <i class="fas fa-boxes-stacked me-2"></i>Productos
            </a>
            <a asp-controller="Admin" asp-action="Ordenes"
               class="nav-link px-3 py-2 @(ViewData["AdminPage"]?.ToString() == "ordenes" ? "active" : "")">
                <i class="fas fa-receipt me-2"></i>Órdenes
            </a>
            <hr class="border-secondary my-2" />
            <a asp-controller="Home" asp-action="Index" class="nav-link px-3 py-2">
                <i class="fas fa-store me-2"></i>Ver Tienda
            </a>
        </nav>
        <div class="text-white-50 small text-center mt-auto pt-3">
            AutoRepuestos Express © @DateTime.Now.Year
        </div>
    </div>

    <!-- Contenido -->
    <div class="flex-grow-1 overflow-auto">
        <div class="bg-white border-bottom px-4 py-3 d-flex justify-content-between align-items-center shadow-sm">
            <h5 class="mb-0 fw-semibold">@ViewData["Title"]</h5>
            <div class="d-flex align-items-center gap-2">
                <i class="fas fa-user-circle fa-lg text-muted"></i>
                <span class="small text-muted">Administrador</span>
            </div>
        </div>

        <div class="p-4">
            @if (TempData["Ok"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Ok"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
