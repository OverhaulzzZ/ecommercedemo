@using EcommerceDemo.Models
@model List<Producto>
@{
    ViewData["Title"] = "Catálogo de Repuestos";
    var categorias = ViewBag.Categorias as List<Categoria> ?? new();
    var marcas = ViewBag.Marcas as List<string> ?? new();
}

<div class="bg-light border-bottom py-2 px-3">
    <div class="container">
        <small class="text-muted">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
            <i class="fas fa-chevron-right mx-1 small"></i> Catálogo
            @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string))
            {
                <i class="fas fa-chevron-right mx-1 small"></i>
                <span>Búsqueda: "@ViewBag.Busqueda"</span>
            }
        </small>
    </div>
</div>

<div class="container py-4">
    <div class="row g-4">
        <!-- Sidebar filtros -->
        <div class="col-lg-3">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-semibold">
                    <i class="fas fa-filter me-2"></i>Filtros
                </div>
                <div class="card-body">
                    <form method="get" asp-controller="Catalogo" asp-action="Index">
                        @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string))
                        {
                            <input type="hidden" name="q" value="@ViewBag.Busqueda" />
                        }

                        <h6 class="fw-semibold mb-2 mt-1">Categoría</h6>
                        <div class="d-flex flex-column gap-1 mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="categoriaId" value="" id="catTodas"
                                       @(ViewBag.CategoriaSeleccionada == null ? "checked" : "") onchange="this.form.submit()" />
                                <label class="form-check-label small" for="catTodas">Todas las categorías</label>
                            </div>
                            @foreach (var cat in categorias)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="categoriaId" value="@cat.Id"
                                           id="cat@(cat.Id)"
                                           @(ViewBag.CategoriaSeleccionada?.ToString() == cat.Id.ToString() ? "checked" : "")
                                           onchange="this.form.submit()" />
                                    <label class="form-check-label small" for="cat@(cat.Id)">@cat.Nombre</label>
                                </div>
                            }
                        </div>

                        <hr class="my-2" />
                        <h6 class="fw-semibold mb-2">Marca</h6>
                        <div class="d-flex flex-column gap-1 mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="marca" value="" id="marcaTodas"
                                       @(string.IsNullOrEmpty(ViewBag.MarcaSeleccionada as string) ? "checked" : "") onchange="this.form.submit()" />
                                <label class="form-check-label small" for="marcaTodas">Todas las marcas</label>
                            </div>
                            @foreach (var m in marcas)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="marca" value="@m"
                                           id="marca@(m.Replace(" ",""))"
                                           @(ViewBag.MarcaSeleccionada == m ? "checked" : "")
                                           onchange="this.form.submit()" />
                                    <label class="form-check-label small" for="marca@(m.Replace(" ",""))">@m</label>
                                </div>
                            }
                        </div>

                        <hr class="my-2" />
                        <h6 class="fw-semibold mb-2">Ordenar por</h6>
                        @{
                            string ordenActual = ViewBag.OrdenSeleccionado as string ?? "";
                        }
                        <select name="orden" class="form-select form-select-sm" onchange="this.form.submit()">
                            <option value="" selected="@(ordenActual == "" ? "selected" : null)">Relevancia</option>
                            <option value="precio_asc" selected="@(ordenActual == "precio_asc" ? "selected" : null)">Precio: menor a mayor</option>
                            <option value="precio_desc" selected="@(ordenActual == "precio_desc" ? "selected" : null)">Precio: mayor a menor</option>
                            <option value="nombre" selected="@(ordenActual == "nombre" ? "selected" : null)">Nombre A-Z</option>
                        </select>

                        <a asp-controller="Catalogo" asp-action="Index" class="btn btn-outline-secondary btn-sm w-100 mt-3">
                            <i class="fas fa-times me-1"></i>Limpiar filtros
                        </a>
                    </form>
                </div>
            </div>
        </div>

        <!-- Grid de productos -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 fw-semibold">
                    @Model.Count repuesto@(Model.Count != 1 ? "s" : "") encontrado@(Model.Count != 1 ? "s" : "")
                </h5>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-search fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">No se encontraron repuestos</h5>
                    <p class="text-muted">Intenta con otros términos o revisa los filtros.</p>
                    <a asp-controller="Catalogo" asp-action="Index" class="btn btn-warning">Ver todos los productos</a>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var p in Model)
                    {
                        <div class="col-sm-6 col-xl-4">
                            <div class="card product-card h-100 shadow-sm">
                                <a asp-controller="Catalogo" asp-action="Detalle" asp-route-id="@p.Id" class="text-decoration-none">
                                    <div class="product-img-wrapper">
                                        <div class="img-placeholder w-100 h-100" style="min-height:180px;">
                                            <i class="fas fa-cog"></i>
                                        </div>
                                    </div>
                                </a>
                                <div class="card-body d-flex flex-column gap-1 p-3">
                                    <div class="d-flex justify-content-between">
                                        <span class="badge bg-light text-secondary border small">@p.Categoria?.Nombre</span>
                                        <span class="text-muted small">@p.SKU</span>
                                    </div>
                                    <a asp-controller="Catalogo" asp-action="Detalle" asp-route-id="@p.Id" class="text-decoration-none text-dark">
                                        <h6 class="card-title fw-semibold mb-1">@p.Nombre</h6>
                                    </a>
                                    <p class="text-muted small mb-1">@p.Marca</p>
                                    <p class="text-muted small mb-2" style="font-size:0.75rem; line-clamp:2; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">
                                        <i class="fas fa-car me-1"></i>@p.CompatibilidadAutos
                                    </p>
                                    <div class="mt-auto">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <span class="precio-tag-sm">$@p.Precio.ToString("F2")</span>
                                            @if (p.Stock > 5)
                                            {
                                                <span class="badge badge-stock-ok small">En stock (@p.Stock)</span>
                                            }
                                            else if (p.Stock > 0)
                                            {
                                                <span class="badge badge-stock-low small">Últimas @p.Stock</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-stock-out small">Agotado</span>
                                            }
                                        </div>
                                        <div class="d-flex gap-2">
                                            <a asp-controller="Catalogo" asp-action="Detalle" asp-route-id="@p.Id"
                                               class="btn btn-outline-dark btn-sm flex-shrink-0">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <form asp-controller="Carrito" asp-action="Agregar" method="post" class="flex-grow-1">
                                                <input type="hidden" name="productoId" value="@p.Id" />
                                                <input type="hidden" name="cantidad" value="1" />
                                                <button type="submit" class="btn btn-add-cart w-100 btn-sm" @(p.Stock == 0 ? "disabled" : "")>
                                                    <i class="fas fa-cart-plus me-1"></i>Agregar
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
